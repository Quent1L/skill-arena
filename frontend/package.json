{
  "name": "skill-arena",
  "version": "1.0.0-beta.5",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun x --bun vite --mode dev",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:unit:cov": "vitest run --coverage",
    "build-only": "bun x --bun vite build --mode prod",
    "type-check": "vue-tsc --noEmit --skipLibCheck",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix --cache",
    "lint": "run-s lint:*",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@fontsource/exo-2": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@primeuix/themes": "^2.0.3",
    "@skill-arena/shared": "workspace:*",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/vue-3": "^3.20.0",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.1.0",
    "better-auth": "*",
    "date-fns": "^4.1.0",
    "primevue": "^4.5.4",
    "tailwindcss-primeui": "^0.6.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "xior": "^0.8.3",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@prettier/plugin-oxc": "^0.1.3",
    "@primevue/auto-import-resolver": "^4.5.4",
    "@tailwindcss/vite": "^4.1.18",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.0.10",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/eslint-plugin": "^1.6.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-oxlint": "~1.41.0",
    "eslint-plugin-vue": "~10.7.0",
    "jiti": "^2.6.1",
    "jsdom": "^27.4.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.41.0",
    "prettier": "3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "*",
    "unplugin-vue-components": "^31.0.0",
    "vite": "7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.3",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  }
}
